# ─── Required ──────────────────────────────────────
SOLANA_PRIVATE_KEY=
HELIUS_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── LLM Provider (OpenRouter recommended) ─────────
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openrouter/owl-alpha

# ─── RPC ────────────────────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}

# ─── Jupiter API (for swaps) ────────────────────────
JUPITER_API_KEY=

# ─── GMGN API (for screening/indicators) ────────────
GMGN_API_KEY=

# ─── OKX API (for auto-swap) ─────────────────────────
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# ─── Optional ────────────────────────────────────────
HIVE_MIND_URL=
HIVE_MIND_API_KEY=
ACTIVE_STRATEGY=bid_ask
DRY_RUN=true
